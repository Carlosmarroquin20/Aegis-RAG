# ── Application ───────────────────────────────────────────────────────────────
APP_NAME="Aegis-RAG"
APP_VERSION="0.1.0"
DEBUG=false

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# In production, inject these from a secrets manager (Vault, AWS Secrets Manager).
VALID_API_KEYS="replace-me-in-production,another-key"
SECURITY_STRICT_MODE=true
API_KEY_HEADER="X-API-Key"

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_BURST=10

# ── Vector Store (ChromaDB) ───────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=aegis_documents

# ── LLM Backend (Ollama) ──────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_SECONDS=120

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json   # "json" for production, "console" for development
